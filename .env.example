# ============================================
# Synkra AIOX Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage)
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# AIOX Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.2.9

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below

# --------------------------------------------
# Control Tower
# --------------------------------------------
# Mode: dev uses local JSON + fake runtimes, real uses Postgres + Docker
CONTROL_TOWER_MODE=dev

# Local dev metadata persistence
CONTROL_TOWER_DATA_FILE=.data/control-tower.json

# Metadata store in real mode
CONTROL_TOWER_METADATA_DATABASE_URL=
CONTROL_TOWER_METADATA_SCHEMA_FILE=packages/control-tower/sql/001_control_plane.sql

# Super Postgres admin connection in real mode
CONTROL_TOWER_SUPER_POSTGRES_URL=
CONTROL_TOWER_PROJECT_DB_HOST=postgres://super-postgres.internal:5432
CONTROL_TOWER_PROJECT_DATABASE_URL_TEMPLATE=postgres://{roleName}:{rolePassword}@127.0.0.1:5433/{databaseName}

# Docker Engine access in real mode
# Provide one of these:
CONTROL_TOWER_DOCKER_BASE_URL=
CONTROL_TOWER_DOCKER_SOCKET_PATH=/var/run/docker.sock
CONTROL_TOWER_DOCKER_NETWORK_NAME=control-tower-net
CONTROL_TOWER_DOCKER_HOST_GATEWAY_NAME=host.docker.internal
CONTROL_TOWER_DOCKER_PUBLISHED_PORT_BASE=11000

# GoTrue provisioning
CONTROL_TOWER_GOTRUE_IMAGE=supabase/auth:v2.192.0
CONTROL_TOWER_GOTRUE_PORT=9999
CONTROL_TOWER_GOTRUE_DB_URL_TEMPLATE=postgres://postgres:<strong-postgres-password>@postgres:5432/{databaseName}?sslmode=disable
CONTROL_TOWER_GOTRUE_SITE_URL_TEMPLATE=https://{subdomain}
CONTROL_TOWER_GOTRUE_EXTERNAL_URL_TEMPLATE=https://{subdomain}/auth
CONTROL_TOWER_GOTRUE_DISABLE_SIGNUP=false
CONTROL_TOWER_GOTRUE_JWT_EXPIRY=3600
CONTROL_TOWER_GOTRUE_JWT_AUDIENCE=authenticated
CONTROL_TOWER_GOTRUE_URI_ALLOW_LIST=https://*.fbr.news,https://*.lab.fbr.news

# PostgREST provisioning (API REST compativel com supabase-js /rest/v1)
CONTROL_TOWER_POSTGREST_IMAGE=postgrest/postgrest:v12.2.3
CONTROL_TOWER_POSTGREST_PORT=3000
CONTROL_TOWER_POSTGREST_DB_URI_TEMPLATE=postgres://authenticator:{authenticatorPassword}@postgres:5432/{databaseName}

# Storage API upstream compartilhado (Opcao B). Define para habilitar /storage/v1 nos subdominios.
# Ex.: http://storage-api:4000 (deixe vazio para desabilitar o routing de storage)
CONTROL_TOWER_STORAGE_UPSTREAM=

# Secret material storage for generated auth keys in real mode
CONTROL_TOWER_SECRET_DIR=.data/secrets

# Caddy route publication
CONTROL_TOWER_CADDY_ADMIN_ORIGIN=http://127.0.0.1:2019
CONTROL_TOWER_CADDY_LISTEN_ADDRESS=:80
CONTROL_TOWER_CADDY_TLS_ENABLED=false
CONTROL_TOWER_CADDY_HTTPS_LISTEN_ADDRESS=:443
CONTROL_TOWER_CADDY_ACME_EMAIL=
CONTROL_TOWER_CADDY_PANEL_DOMAIN=control-tower.fbr.news
CONTROL_TOWER_CADDY_PANEL_UPSTREAM=http://host.docker.internal:3000
CONTROL_TOWER_STORAGE_ROOT=.data/storage
CONTROL_TOWER_IMPORT_ROOT=.data/imports
CONTROL_TOWER_BACKUP_ROOT=.data/backups
CONTROL_TOWER_BACKUP_RETENTION_COUNT=12
CONTROL_TOWER_CACHE_ROOT=.data/cache
CONTROL_TOWER_HOT_STORAGE_ROOT=.data/storage-hot
CONTROL_TOWER_COLD_STORAGE_ROOT=.data/storage-cold

# Admin panel auth
# Preferred: point to a dedicated GoTrue instance for the panel.
CONTROL_TOWER_ADMIN_AUTH_URL=
CONTROL_TOWER_ADMIN_AUTH_API_KEY=
CONTROL_TOWER_ADMIN_ALLOWED_EMAILS=admin@fbr.news
CONTROL_TOWER_ADMIN_SESSION_SECRET=

# Local bootstrap fallback for development only when GoTrue admin is not wired yet
CONTROL_TOWER_ADMIN_BOOTSTRAP_EMAIL=admin@fbr.news
CONTROL_TOWER_ADMIN_BOOTSTRAP_PASSWORD=

# Project domain templates for the panel and smoke scripts
NEXT_PUBLIC_CONTROL_TOWER_PROJECT_SUBDOMAIN_TEMPLATE={slug}.control-tower.fbr.news
NEXT_PUBLIC_CONTROL_TOWER_PROJECT_IMPORT_SUBDOMAIN_TEMPLATE={slug}-import.control-tower.fbr.news
