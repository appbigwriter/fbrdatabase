+/**
+ * RoutePublisher that pushes the full config to a running Caddy via its admin API.
+ * Used in real mode so provisioning a project makes its subdomain live immediately.
+ */
+export class CaddyAdminRoutePublisher implements RoutePublisher {
+  constructor(private readonly options: CaddyPublishOptions) {}
+
+  async publishRoutes(snapshot: MetadataSnapshot): Promise<void> {
+    const config = buildCaddyRouteConfig(snapshot, this.options);
+    await publishCaddyConfig(config);
+  }
+}
+
+/**
+ * RoutePublisher that writes the generated config to a file instead of calling Caddy.
+ * Handy for local inspection / dev without a live admin API.
+ */
+export class CaddyFileRoutePublisher implements RoutePublisher {
+  constructor(
+    private readonly filePath: string,
+    private readonly options: CaddyPublishOptions
+  ) {}
+
+  async publishRoutes(snapshot: MetadataSnapshot): Promise<void> {
+    const config = buildCaddyRouteConfig(snapshot, this.options);
+    await writeCaddyConfigFile(this.filePath, config);
+  }
+}
